@book{adams_understanding_2003,
	title = {Understanding {PKI}: Concepts, Standards, and Deployment Considerations},
	isbn = {978-0-672-32391-1},
	shorttitle = {Understanding {PKI}},
	abstract = {Public-Key Infrastructure ({PKI}) is the foundation of the four major elements of digital security: authentication, integrity, confidentiality, and non-repudiation. The idea of a public-key infrastructure has existed for more than a decade, but the need for {PKI} has intensified over the last few years as the Internet has expanded its reach into business, government, the legal system, the military, and other areas that depend on secure communications. "Understanding {PKI}, Second Edition, " is both a guide for software engineers involved in {PKI} development and a readable resource for technical managers responsible for their organization's security policies and investments. It is a comprehensive primer to the latest in {PKI} technology and how it is used today. Taking a non-vendor-specific approach, this book explains fundamental concepts, examines emerging standards, and discusses deployment considerations and strategies that effect success.This second edition has been updated throughout to incorporate all of the most recent developments in the {PKI} field. Two new chapters have been added to address the use of {PKI} in the real world and to explore the technology's future. This new edition also addresses: The X.509 {standardPKI} for {privacyThe} emergence of electronic signatures and accompanying {legislationNew} {PKI} initiatives supported by the {XML} standards {bodiesIn} addition to this specific information, the authors lend their informed opinions on how emerging trends will drive the expansion of {PKI}.  0672323915B10162002},
	pagetotal = {360},
	publisher = {Addison-Wesley Professional},
	author = {Adams, Carlisle and Lloyd, Steve},
	date = {2003},
	langid = {english},
	note = {Google-Books-{ID}: {ERSfUmmthMYC}},
	keywords = {Computers / Database Administration \& Management, Computers / Electronic Commerce, Computers / Internet / Online Safety \& Privacy, Computers / Networking / General, Computers / Security / General, Computers / Security / Network Security},
}

@inproceedings{zhao_pki-based_2007,
	title = {{PKI}-Based Authentication Mechanisms in Grid Systems},
	url = {https://ieeexplore.ieee.org/document/4286412/},
	doi = {10.1109/NAS.2007.42},
	abstract = {Grids have emerged as the basic infrastructure for high performance distributed computing and data collaborations. Although they depict an attractive new world of computing, security is the biggest barrier against wide adoption of Grids. Authentication is the basis of security in grids. {GSI} uses X.509 {PKI} and proxy certificates as authentication foundation, and uses gateway for mapping certificates between different authentication mechanisms. In this article, we review {PKI} and {PKI}-based authentication mechanisms used in grid systems. These mechanisms are insufficient or problematic under some circumstances. We study and analyze some prominent challenges or problems: compatibility across different {PKIs}, proxy certificate revocation, security weakness, and authentication in ad hoc grids. For each of them, we introduce possible solutions, and analyze state-of-the-art technologies and ongoing researches that indicate the direction of future work on this topic.},
	eventtitle = {2007 International Conference on Networking, Architecture, and Storage ({NAS} 2007)},
	pages = {83--90},
	booktitle = {2007 International Conference on Networking, Architecture, and Storage ({NAS} 2007)},
	author = {Zhao, Shushan and Aggarwal, Akshai and Kent, Robert D.},
	urldate = {2026-05-06},
	date = {2007-07},
	keywords = {Authentication, Authorization, Communication system security, Cryptographic protocols, Data security, Digital signatures, Distributed computing, Grid computing, Personal communication networks, Public key},
	file = {Full Text PDF:/home/william/snap/zotero-snap/common/Zotero/storage/CQ9MTPI9/Zhao et al. - 2007 - PKI-Based Authentication Mechanisms in Grid Systems.pdf:application/pdf},
}

@inproceedings{oniga_iot_2018,
	title = {{IoT} Infrastructure Secured by {TLS} Level Authentication and {PKI} Identity System},
	url = {https://ieeexplore.ieee.org/document/8611563/},
	doi = {10.1109/WorldS4.2018.8611563},
	abstract = {Internet of Things ({IoT}) networks continuously connect devices and provide environmental information, offering new possibilities for business and personal life. The need for security has never been greater in such ecosystems due to the fast expansion registered lately. The paper proposes a Public Key Infrastructure ({PKI}) authentication model for {IoT} networks which provides trust and full control of the authenticated parties. By implementing the proposed authentication model, essential security requirements are achieved by providing certificate-based device (gateway, sensor) authentication and user authentication on the web platform for admin-management and web panel for device administration. In this context, this paper performs an in-depth analysis of the proposed authentication model and its security aspects.},
	eventtitle = {2018 Second World Conference on Smart Trends in Systems, Security and Sustainability ({WorldS}4)},
	pages = {78--83},
	booktitle = {2018 Second World Conference on Smart Trends in Systems, Security and Sustainability ({WorldS}4)},
	author = {Oniga, Bogdan and Farr, Stefan Harsan and Munteanu, Adrian and Dadarlat, Vasile},
	urldate = {2026-05-06},
	date = {2018-10},
	keywords = {Authentication, Identity Plus, Internet of Things, Logic gates, Network servers, networks, {PKI}, Protocols, Public key cryptography, security},
	file = {Full Text PDF:/home/william/snap/zotero-snap/common/Zotero/storage/8A8KQ4Z8/Oniga et al. - 2018 - IoT Infrastructure Secured by TLS Level Authentication and PKI Identity System.pdf:application/pdf},
}

@article{danquah_public_2020,
	title = {Public Key Infrastructure: An Enhanced Validation Framework},
	volume = {11},
	rights = {http://creativecommons.org/licenses/by/4.0/},
	issn = {2153-1234, 2153-1242},
	url = {https://www.scirp.org/journal/paperinformation?paperid=103117},
	doi = {10.4236/jis.2020.114016},
	shorttitle = {Public Key Infrastructure},
	abstract = {Public Key Infrastructure ({PKI}) is a comprehensive information security framework for providing secure information and communication over the internet. Its need and use has grown over the years and continually grows. This research work examines the current {PKI} framework’s validation process as operated by vendors and subscribers to identify the drawbacks and propose enhanced approaches to its validation mechanism. Using an approach of reviewing secondary data, critical weaknesses of integrity, proof of trust and single point-of-failure were identified with the current {PKI} framework. This study therefore advances proposed solutions to address the identified weaknesses by specifically introducing multiple Certificate Authorities, storage, visibility and searchability of subscriber information in public repository. A comprehensive detail of its implementation is proposed to address the identified weaknesses of uncertain integrity, trust for certificate authorities and prevent a single point of failure. Furthermore, the proposed enhancements are validated with the protection motivation theory and a framework for empirically testing the enhancements is suggested. Further research would be required to factor in multi-factor authentication without compromising performance.},
	pages = {241--260},
	number = {4},
	journaltitle = {Journal of Information Security},
	shortjournal = {{JIS}},
	author = {Danquah, Paul and Kwabena-Adade, Henoch},
	urldate = {2026-05-06},
	date = {2020},
	langid = {english},
	file = {PDF:/home/william/snap/zotero-snap/common/Zotero/storage/W88MGRM5/Danquah and Kwabena-Adade - 2020 - Public Key Infrastructure An Enhanced Validation Framework.pdf:application/pdf},
}

