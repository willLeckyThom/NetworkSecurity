@startuml stride_dfd
title STRIDE — Data Flow Diagram\nMilestone 1 : Initial Setup (sans VPN / Firewall)

skinparam defaultFontName Helvetica
skinparam defaultFontSize 10
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam ranksep 35
skinparam nodesep 25

skinparam rectangle {
  BackgroundColor #FFFFFF
  BorderColor     #333333
  BorderThickness 2
  FontSize        10
  FontStyle       bold
}
skinparam usecase {
  BackgroundColor #DDEEFF
  BorderColor     #2255AA
  BorderThickness 1.5
  FontSize        10
}
skinparam database {
  BackgroundColor #E8F5E9
  BorderColor     #2E7D32
  BorderThickness 1.5
  FontSize        10
}
skinparam ArrowColor     #333333
skinparam ArrowFontSize  8
skinparam ArrowFontColor #333333
skinparam ArrowThickness 1.2
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor     #F9A825
  FontSize        8
}
skinparam package {
  BackgroundColor #00000000
  BorderColor     #CC0000
  BorderThickness 1.5
  FontColor       #CC0000
  FontSize        9
  FontStyle       italic
  BorderStyle     dashed
}


' ============================================================
' ZONE EXTERNE — Internet (untrusted)
' R1 est côté externe car c'est le point d'entrée internet
' ============================================================
package "Internet (Untrusted Zone)" {
  rectangle "Remote-\nEmployee" as RE
  rectangle "Malicious\nPC"     as MAL
  usecase "Router R1" as R1
}

' ============================================================
' ZONE ENTREPRISE — trusted
' ============================================================
package "Enterprise Network (Trusted Zone)" {

  package "Office Network" {
    usecase "Router R2"        as R2
    usecase "PC-1\n(IT Dept.)" as PC1
    usecase "PC-2\n(HR Dept.)" as PC2
  }

  ' Sans firewall, pas de vraie DMZ — simple Server Network
  package "Server Network" {
    usecase "Router R3"          as R3
    database "Server-1\n(NGINX)" as S1
    database "Server-2\n(NGINX)" as S2
  }
}

' ============================================================
' FLUX — TOUS passent par R2 (topologie réelle)
' Pas de lien direct R1-R3 dans la topologie initiale
' ============================================================

' F1 — Remote-Employee → office (via R1 → R2)
RE  --> R1 : F1
R1  --> R2 : F1
R2  --> PC1 : F1
R2  --> PC2 : F1

' F2 — Malicious PC → office (A2 : Spoofing)
' Même chemin R1→R2, rien ne bloque
MAL --> R1 : F2
R1  --> R2 : F2

' F3 — PCs → serveurs (usage interne IT)
PC1 --> R2 : F3
PC2 --> R2 : F3
R2  --> R3 : F3
R3  --> S1 : F3
R3  --> S2 : F3

' F4 — Malicious PC → serveurs (A1)
' Chemin : MAL → R1 → R2 → R3 → S1/S2
' Pas de lien direct R1-R3, tout passe par R2
MAL --> R1 : F4
R1  --> R2 : F4
R2  --> R3 : F4
R3  --> S1 : F4
R3  --> S2 : F4

' F5 — pivot serveur → office (A5)
' Serveur compromis initie connexion vers office
S1  --> R3 : F5
R3  --> R2 : F5
R2  --> PC1 : F5

' F6 — RIPv2 entre routeurs (A3 : route poisoning)
R1 <--> R2 : F6
R2 <--> R3 : F6

' F7 — réponses HTTP des serveurs
S1  --> R3 : F7
S2  --> R3 : F7

@enduml
